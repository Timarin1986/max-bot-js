{
  "name": "max-bot",
  "version": "1.0.0",
  "description": "Бот для тестирования по промышленной безопасности в MAX",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "keywords": ["max", "bot", "testing"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "axios": "^1.6.8",
    "dotenv": "^16.4.5",
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "cross-env": "^7.0.3",
    "jest": "^30.4.2"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "collectCoverageFrom": ["index.js"],
    "coveragePathIgnorePatterns": ["/node_modules/", "/__tests__/"],
    "testMatch": ["**/__tests__/**/*.test.js"]
  }
}